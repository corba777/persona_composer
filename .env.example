# Copy to `.env` in the repo root and fill in what you need.
# Keys present here unlock OpenAI / Anthropic presets in the Streamlit playground.
# Without them, only Vertex AI backends are offered.

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional default for Vertex UI field:
# GOOGLE_CLOUD_PROJECT=your-gcp-project
